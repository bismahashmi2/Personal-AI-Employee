# AI Employee Vault - Environment Variables
# Copy this file to .env and fill in your actual credentials
# DO NOT commit .env to git!

# Email Configuration (Gmail example)
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# LinkedIn API (OAuth 2.0 - for business opportunity monitoring)
# Get these from LinkedIn Developer Portal → Settings → Authentication keys
LINKEDIN_CLIENT_ID=your-client-id
LINKEDIN_CLIENT_SECRET=your-client-secret

# Claude API (for actual AI reasoning - optional, for future enhancement)
ANTHROPIC_API_KEY=your-claude-api-key

# Optional: Odoo credentials (for Gold Tier)
ODOO_URL=http://localhost:8069
ODOO_DB=your-database
ODOO_USER=admin
ODOO_PASSWORD=your-odoo-password
